# ═══════════════════════════════════════════════════════════════
# AI Video Pipeline — 环境变量模板
# 复制此文件为 .env 并填入真实值。
# 完整文档: docs/claude/debt-audit/debt-audit-report-2026-06-09.md
# ═══════════════════════════════════════════════════════════════

# ── 日志级别 ──
# 可选值: DEBUG / INFO / WARNING / ERROR。默认 INFO。
LOG_LEVEL=INFO

# ── 文本 LLM：DeepSeek-V4-Pro 原生 ──
# 官方文档：https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ── 图像+视频：poyo.ai ──
# GPT-4o Image: https://docs.poyo.ai/api-manual/image-series/gpt-4o-image
# Seedance 2:   https://docs.poyo.ai/api-manual/video-series/happy-horse
POYO_API_KEY=sk-your-poyo-key
POYO_API_BASE_URL=https://api.poyo.ai
POYO_IMAGE_MODEL=gpt-image-2
POYO_VIDEO_MODEL=seedance-2

# poyo 图像任务轮询上限（默认 72 次，每次间隔 5 秒，约 6 分钟超时）
POYO_IMAGE_MAX_POLLS=72

# ── 语音 TTS：硅基流动 CosyVoice ──
# 官方文档：https://docs.siliconflow.cn/cn/api-reference/audio/create-speech
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
COSYVOICE_MODEL=FunAudioLLM/CosyVoice2-0.5B
COSYVOICE_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex
COSYVOICE_VOICE_FEMALE=FunAudioLLM/CosyVoice2-0.5B:anna

# poyo TTS (备选，默认 generate-music)
POYO_TTS_MODEL=generate-music

# ── Seedance 直连配置（备选，绕过 poyo 代理）──
SEEDANCE_API_KEY=
SEEDANCE_API_BASE_URL=https://api.seedance.ai

# ── 遗留 LLM 配置（向后兼容，不再用于 Pro 版主链路）──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# ── LLM Provider 路由 ──
# Pro 版本使用 deepseek；如需回退到 kimi，改为 "kimi"
DEFAULT_LLM_PROVIDER=deepseek

# Kimi 模型名称（仅当 DEFAULT_LLM_PROVIDER=kimi 时使用）
KIMI_MODEL=kimi-k2-0905-preview

# ── LLM Client 硬编码 URL 集中管理 ──
# 一般无需修改；仅当 provider 更换 API 域名时调整。
KIMI_API_BASE=https://api.moonshot.cn/v1
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_API_BASE=https://api.openai.com/v1
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1

# ── Database ──
DATABASE_URL=postgresql://ai_video:ai_video_dev_2026@localhost:5432/ai_video

# PG fallback: 设为 1 时 brand_package / influencer 走 PG 持久化
BRAND_PACKAGE_USE_PG=

# ── Supabase (optional) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Backend ──
ENVIRONMENT=development
API_KEY=local-dev-api-key-change-me
TEST_BUNDLE_KEY=ai_video_demo_2026
ALLOW_TEST_BUNDLE_KEY=0
VIDEO_OUTPUT_DIR=./output

# Mock 模式开关: 设为 1 时允许在无真实 API key 时走 mock 链路
ALLOW_MOCK_MODE=

# Mock 产品数据（用于演示 / 测试）
MOCK_PRODUCT_NAME=X1
MOCK_PRODUCT_CATEGORY=wearable breast pump

# ── Rendering Service (Remotion) ──
# 独立渲染服务地址，默认空表示不用外部渲染
RENDERING_SERVICE_URL=

# ── Media Signing ──
# 媒体签名密钥，默认回退到 API_KEY
MEDIA_SIGN_SECRET=

# ── Quality Checks (Round 3) ──
# Mode: off = 禁用所有新质量检查
#       observe = 运行检查并记录到 metadata，不阻塞 pipeline（默认）
#       enforce = 检查失败时阻塞 pipeline
QUALITY_MODE=observe

# Frame variance 阈值（seedance_video_generate 黑屏/静态图检测）
FRAME_VARIANCE_MSE_THRESHOLD=50.0
FRAME_VARIANCE_BRIGHTNESS_THRESHOLD=20.0

# AV sync 阈值（remotion_assemble 音视频同步检测）
AV_SYNC_MAX_ABS_DIFF=0.5
AV_SYNC_MAX_REL_DIFF=0.05

# 视频规格阈值（media_quality_audit 最终输出检测）
VIDEO_MIN_FPS=25.0
VIDEO_CRITICAL_FPS=20.0
VIDEO_MIN_BITRATE_KBPS=1500
VIDEO_CRITICAL_BITRATE_KBPS=1000
VIDEO_ASPECT_RATIO_MIN=0.53
VIDEO_ASPECT_RATIO_MAX=0.60

# ── Auto-pilot 优化 ──
# 设为 1 时 auto 模式跳过缩略图生成步骤（提速 15-30 秒）
SKIP_THUMBNAIL_IN_AUTO=

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_KEY=local-dev-api-key-change-me
NEXT_PUBLIC_API_BASE_URL=

# ── CORS ──
CORS_ORIGINS=

# ── Platform APIs (optional) ──
TIKTOK_ACCESS_TOKEN=
TIKTOK_USERNAME=
SHOPIFY_API_KEY=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_PASSWORD=
SHOPIFY_STORE_URL=
YOUTUBE_API_KEY=
FACEBOOK_ACCESS_TOKEN=

# ── TikTok API URLs (一般无需修改) ──
TIKTOK_API_UPLOAD_URL=https://open-api.tiktok.com
SHOPIFY_GRAPHQL_URL_TEMPLATE=https://{store}/admin/api/2024-07/graphql.json

# ── Webhook 通知 ──
# 逗号分隔的 webhook URL，收到 pipeline.completed / audit.completed 事件时推送
WEBHOOK_URLS=

# ── Admin Panel ──
# 错误日志保留天数（默认 30）
ADMIN_LOG_RETENTION_DAYS=30
# 默认 0：admin health 不主动探测 DeepSeek/poyo/SiliconFlow，避免污染 token smoke 日志。
# 如需在 Admin Panel 展示 provider 在线探测，显式改为 1。
ADMIN_EXTERNAL_PROVIDER_HEALTH_CHECKS_ENABLED=0

# ── C2PA Content Credentials (Sprint 3 P3-1, EU AI Act 2026-08-02) ──
# Disabled by default. Activate by setting C2PA_ENABLED=1 + provisioning
# X.509 cert + key from a CAI-trusted issuer (DigiCert / Adobe CAI). Without
# both env + cert files, sign_video() is a no-op (returns unsigned input).
# See src/tools/c2pa_signer.py docstring for the full deploy checklist.
C2PA_ENABLED=
C2PA_CERT_PATH=
C2PA_KEY_PATH=
C2PA_TSA_URL=http://timestamp.digicert.com

# ── S3 Copyright Safety (ADR-004 Option D) ──
# 默认 1 = 禁用 S3 病毒视频提取。仅在法务签字后改为 0。
S3_VIRAL_EXTRACT_DISABLED=1

# ── 应用版本（运行时注入，一般无需手动设置）──
APP_VERSION=
