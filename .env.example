# ── LLM / AI API Keys ──
OPENAI_API_KEY=sk-your-key-here       # Kimi/OpenAI compatible (LLM + GPT-Image)
POYO_API_KEY=sk-poyo-your-key-here    # poyo.ai proxy for Seedance 2.0
ELEVENLABS_API_KEY=                   # Optional: TTS (leave empty for stub audio)
ANTHROPIC_API_KEY=                    # Optional: Claude (not currently used)

# ── Database ──
DATABASE_URL=postgresql://ai_video:ai_video_dev_2026@localhost:5432/ai_video

# ── Backend ──
API_KEY=ai_video_demo_2026           # Shared secret between backend and frontend
DEFAULT_LLM_PROVIDER=kimi            # kimi | openai | claude
VIDEO_OUTPUT_DIR=./output            # Output directory for generated media

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_KEY=ai_video_demo_2026  # Must match backend API_KEY
NEXT_PUBLIC_API_BASE_URL=                # Deployment: set to backend URL (e.g. https://lute-ai-video-api.onrender.com)
                                         # Leave empty for localhost:8001 (local dev)

# ── CORS (backend) ──
CORS_ORIGINS=                            # Comma-separated allowed origins for production
                                         # e.g. https://lute-ai-video.vercel.app,https://lute-ai-video-demo.vercel.app

# ── Platform APIs (optional, for distribution) ──
TIKTOK_ACCESS_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_STORE_URL=
YOUTUBE_API_KEY=
