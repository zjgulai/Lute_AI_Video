# ═══════════════════════════════════════════════════════════════
# Pro 版 API 配置（DeepSeek V4-Pro + poyo + 硅基流动 CosyVoice）
# ═══════════════════════════════════════════════════════════════

# ── 文本 LLM：DeepSeek-V4-Pro 原生 ──
# 官方文档：https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ── 图像+视频：poyo.ai ──
# GPT-4o Image: https://docs.poyo.ai/api-manual/image-series/gpt-4o-image
# Happy Horse:  https://docs.poyo.ai/api-manual/video-series/happy-horse
POYO_API_KEY=sk-your-poyo-key
POYO_API_BASE_URL=https://api.poyo.ai
POYO_IMAGE_MODEL=gpt-image-2
POYO_VIDEO_MODEL=seedance-2

# ── 语音 TTS：硅基流动 CosyVoice ──
# 官方文档：https://docs.siliconflow.cn/cn/api-reference/audio/create-speech
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
COSYVOICE_MODEL=FunAudioLLM/CosyVoice2-0.5B
COSYVOICE_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex

# ── 遗留配置（向后兼容，不再用于 Pro 版主链路）──
OPENAI_API_KEY=                        # 之前用于 Kimi LLM，现由 DEEPSEEK_API_KEY 替代
ANTHROPIC_API_KEY=                     # 未使用
ELEVENLABS_API_KEY=                    # 未使用（CosyVoice 替代）

# ── LLM Provider 路由 ──
# Pro 版本使用 deepseek；如需回退到 kimi，改为 "kimi"
DEFAULT_LLM_PROVIDER=deepseek

# ── Database ──
DATABASE_URL=postgresql://ai_video:ai_video_dev_2026@localhost:5432/ai_video

# ── Backend ──
ENVIRONMENT=development
API_KEY=local-dev-api-key-change-me
TEST_BUNDLE_KEY=ai_video_demo_2026
ALLOW_TEST_BUNDLE_KEY=0
VIDEO_OUTPUT_DIR=./output

# ── Quality Checks (Round 3) ──
# Mode: off = 禁用所有新质量检查
#       observe = 运行检查并记录到 metadata，不阻塞 pipeline（默认）
#       enforce = 检查失败时阻塞 pipeline
QUALITY_MODE=observe

# Frame variance 阈值（seedance_video_generate 黑屏/静态图检测）
FRAME_VARIANCE_MSE_THRESHOLD=50.0
FRAME_VARIANCE_BRIGHTNESS_THRESHOLD=20.0

# AV sync 阈值（remotion_assemble 音视频同步检测）
AV_SYNC_MAX_ABS_DIFF=0.5
AV_SYNC_MAX_REL_DIFF=0.05

# 视频规格阈值（media_quality_audit 最终输出检测）
VIDEO_MIN_FPS=25.0
VIDEO_CRITICAL_FPS=20.0
VIDEO_MIN_BITRATE_KBPS=1500
VIDEO_CRITICAL_BITRATE_KBPS=1000
VIDEO_ASPECT_RATIO_MIN=0.53
VIDEO_ASPECT_RATIO_MAX=0.60

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_KEY=local-dev-api-key-change-me
NEXT_PUBLIC_API_BASE_URL=

# ── CORS ──
CORS_ORIGINS=

# ── Platform APIs (optional) ──
TIKTOK_ACCESS_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_STORE_URL=
YOUTUBE_API_KEY=

# ── C2PA Content Credentials (Sprint 3 P3-1, EU AI Act 2026-08-02) ──
# Disabled by default. Activate by setting C2PA_ENABLED=1 + provisioning
# X.509 cert + key from a CAI-trusted issuer (DigiCert / Adobe CAI). Without
# both env + cert files, sign_video() is a no-op (returns unsigned input).
# See src/tools/c2pa_signer.py docstring for the full deploy checklist.
C2PA_ENABLED=
C2PA_CERT_PATH=
C2PA_KEY_PATH=
C2PA_TSA_URL=http://timestamp.digicert.com
