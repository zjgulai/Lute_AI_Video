FROM python:3.12.13-slim-trixie@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de
COPY --from=ghcr.io/astral-sh/uv:0.11.11@sha256:798712e57f879c5393777cbda2bb309b29fcdeb0532129d4b1c3125c5385975a /uv /uvx /bin/
WORKDIR /app

# 2026-05-15 incident: apt-get install system media/build packages
# packages) hung 74+ min on deb.debian.org from China. Switch to Aliyun mirror
# before any apt-get call. Debian 13 Trixie uses deb822 format in
# sources.list.d/debian.sources, not the legacy /etc/apt/sources.list.
# Override-able via APT_MIRROR build-arg for overseas builds.
ARG APT_MIRROR=mirrors.aliyun.com
RUN if [ -f /etc/apt/sources.list.d/debian.sources ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    if [ -f /etc/apt/sources.list ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list; \
    fi

# Install the only runtime system dependency. All Python packages used here
# have reviewed CPython 3.12 wheels in uv.lock, including psycopg[binary] and
# Pillow, so compiler and development headers must not remain in the image.
#   - ffmpeg: required by validated local media probes, stub generation, and
#     frame extraction. yt-dlp is explicitly single-format/native/fixup-never;
#     it must not invoke ffmpeg before the downloaded bytes pass safe-media.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg && \
    rm -rf /var/lib/apt/lists/*

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked --no-dev --no-install-project

# Copy all backend source code
COPY src ./src
COPY scripts ./scripts
COPY configs ./configs

# Phase 0 #1 (2026-05-15): alembic migrations must travel with the image so
# scripts/run_alembic_upgrade.sh can find /app/migrations inside the running
# container. Before this, only source and dependency declaration files were in
# the image, so alembic upgrade failed with "Path doesn't exist: alembic".
COPY migrations ./migrations

# P1-15: Copy strategy_source/ and rendering/ so the container behaves
# identically to local dev. strategy_source/ contains scenario configs and
# quality thresholds; rendering/ contains Remotion templates referenced by
# remotion_assemble.py and remotion_renderer.py.
# NOTE: rendering/node_modules/ should be excluded via .dockerignore (201MB+)
# and installed inside the container if Remotion rendering runs there.
COPY strategy_source ./strategy_source
COPY rendering ./rendering

# Create output directory (used by VIDEO_OUTPUT_DIR)
RUN mkdir -p /app/output

# P3-3: Run as non-root user for security
RUN groupadd -r appgroup && useradd -r -g appgroup appuser && \
    chown -R appuser:appgroup /app

# Release identity is metadata-only. Keep it after all filesystem layers so a
# new reviewed SHA cannot invalidate the pinned apt and uv dependency layers.
ARG RELEASE_SOURCE_SHA
LABEL org.opencontainers.image.revision="${RELEASE_SOURCE_SHA}"
USER appuser

ENV PYTHONPATH=/app
ENV PATH="/app/.venv/bin:$PATH"
EXPOSE 8001
CMD ["uvicorn", "src.api:app", "--host", "0.0.0.0", "--port", "8001"]
